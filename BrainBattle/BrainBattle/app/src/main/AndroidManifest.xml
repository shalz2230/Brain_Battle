<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo3"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BrainBattle"
        tools:targetApi="31">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BrainBattle">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LOGIN -->
        <activity android:name=".LoginActivity" />

        <!-- SIGNUP -->
        <activity android:name=".SignupActivity" />

        <!-- HOME SCREEN -->
        <activity android:name=".HomeActivity" />

        <!-- MEMORY LEVELS -->
        <activity android:name=".MemoryLevelsActivity" />

        <!-- MEMORY GAME -->
        <activity android:name=".GameActivity" />

        <!-- ALL GAME RESULT -->
        <activity android:name=".ResultActivity" />

        <!-- LOGIC LEVELS -->
        <activity android:name=".LogicLevelsActivity" />

        <!-- LOGIC GAME -->
        <activity android:name=".LogicGameActivity" />

        <!-- FOCUS LEVELS -->
        <activity android:name=".FocusLevelsActivity" />

        <!-- FOCUS GAME -->
        <activity android:name=".FocusGameActivity" />

        <!-- SPEED LEVELS -->
        <activity android:name=".SpeedLevelsActivity" />

        <!-- SPEED GAME -->
        <activity android:name=".SpeedGameActivity" />

        <activity android:name=".LevelsActivity"/>
        <activity android:name=".RankActivity"/>
        <activity android:name=".ProfileRankActivity"/>

        <activity android:name=".ForgotPasswordActivity"/>
        <activity android:name=".ChangePasswordActivity"/>

    </application>

</manifest>