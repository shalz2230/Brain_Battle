{
  "name": "brainbattle-selenium-tests",
  "version": "1.0.0",
  "description": "Selenium / API E2E Tests for Brain Battle Backend (Node.js)",
  "main": "index.js",
  "scripts": {
    "test": "mocha \"tests/**/*.test.js\" \"e2e_web/**/*.test.js\" --timeout 15000 --reporter spec",
    "test:auth": "mocha tests/auth.test.js --timeout 15000 --reporter spec",
    "test:user": "mocha tests/user.test.js --timeout 15000 --reporter spec",
    "test:progress": "mocha tests/progress.test.js --timeout 15000 --reporter spec",
    "test:dashboard": "mocha tests/dashboard.test.js --timeout 15000 --reporter spec",
    "report": "node generate_report.js",
    "test:report": "npm test && node generate_report.js"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "chromedriver": "^149.0.2",
    "mocha": "^10.3.0",
    "selenium-webdriver": "^4.44.0"
  }
}
